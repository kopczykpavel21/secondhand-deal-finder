# ─── Runtime mode ────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Mock adapters ────────────────────────────────────────────────────────────
# Set to "true" to use mock data (no real scraping). Ideal for local UI dev.
USE_MOCK_ADAPTERS=true

# ─── Source feature flags ─────────────────────────────────────────────────────
# Bazoš is always enabled (most reliable source).

# Sbazar — partial support. Set to "false" to disable.
ENABLE_SBAZAR=true

# Vinted — experimental. Disabled by default due to fragility.
ENABLE_VINTED=false

# Facebook Marketplace — experimental. Requires auth to work reliably.
# Disabled by default.
ENABLE_FACEBOOK=false

# ─── Playwright config ────────────────────────────────────────────────────────
# Set to "false" to show browser window (useful for debugging scrapers)
PLAYWRIGHT_HEADLESS=true

# ─── Optional: Redis cache URL ────────────────────────────────────────────────
# Leave empty to disable caching
# REDIS_URL=redis://localhost:6379

# ─── Optional: Database (not used in Phase 1 MVP) ────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/sdf
